# tmonitor.conf - configuracao do TMonitor para este diretorio de projeto.
# Apenas CMD1 e obrigatorio; todo o resto tem default.

SESSION_NAME="My Laravel App Monitor"

# Layout dos panes de comando: columns (default) | rows | grid
LAYOUT="columns"

# Altura do shell interativo no rodape, em porcentagem (10-90, default 30)
SHELL_HEIGHT="30"

# Estatisticas de CPU/memoria/disco na status bar: on (default) | off
STATS="on"

# Comandos dos panes (CMD1..CMDN, numeracao sequencial sem buracos)
# e labels opcionais exibidos na borda de cada pane (LABEL1..LABELN)
CMD1="tail -f storage/logs/laravel.log"
LABEL1="logs"

CMD2="composer dumpa && php artisan optimize:clear && npm run build && php artisan queue:work"
LABEL2="queue"

CMD3="php artisan command:run-custom-command"
LABEL3="custom"

CMD4="php artisan horizon"
LABEL4="horizon"
